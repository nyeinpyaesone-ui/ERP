# AI ERP System Environment Configuration
# Copy this file to .env and update values for your environment

# Application Settings
DEBUG=False
APP_NAME="AI ERP System"
APP_VERSION="3.3.0"

# Database Configuration
DATABASE_URL=postgresql://erp_user:CHANGE_ME@localhost:5432/erp_db
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=erp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security Settings
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Data Directory
DATA_DIR=data
