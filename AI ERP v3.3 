"""
Logistics Agent Skills – Deterministic delivery fee, route, and ETA.
Zero token cost – all queries use PostgreSQL + pgvector.
"""

from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import text
from typing import Optional, Dict, Any
import logging

logger = logging.getLogger(__name__)

async def get_delivery_fee(
    db: AsyncSession,
    township_query: str,
    weight_kg: float = 1.0
) -> Optional[Dict[str, Any]]:
    """Get delivery fee and estimate for a township, with semantic fallback."""
    # 1. Exact match
    row = await db.execute(
        text("""
            SELECT name_en, name_mm, delivery_fee_mmk, delivery_zone, estimated_days
            FROM active_townships
            WHERE name_en ILIKE :q OR name_mm ILIKE :q
        """),
        {"q": f"%{township_query}%"}
    )
    result = row.first()
    if result:
        return {
            "township": township_query,
            "matched_name": result.name_en,
            "delivery_fee_mmk": float(result.delivery_fee_mmk),
            "delivery_zone": result.delivery_zone,
            "estimated_days": result.estimated_days,
            "semantic_match": False
        }

    # 2. Semantic fallback
    try:
        row = await db.execute(
            text("""
                SELECT name_en, name_mm, delivery_fee_mmk, delivery_zone, estimated_days
                FROM townships
                WHERE name_mm ILIKE :q OR name_en ILIKE :q
                ORDER BY
                    CASE
                        WHEN name_en ILIKE :q THEN 1
                        WHEN name_mm ILIKE :q THEN 2
                        ELSE 3
                    END
                LIMIT 1
            """),
            {"q": f"%{township_query}%"}
        )
        result = row.first()
        if result:
            return {
                "township": township_query,
                "matched_name": result.name_en,
                "delivery_fee_mmk": float(result.delivery_fee_mmk),
                "delivery_zone": result.delivery_zone,
                "estimated_days": result.estimated_days,
                "semantic_match": True
            }
    except Exception as e:
        logger.warning(f"Semantic search fallback failed: {e}")

    return None

async def get_trucking_cost(
    db: AsyncSession,
    origin: str,
    destination: str,
    weight_kg: float
) -> Optional[Dict[str, Any]]:
    """Get cost and time for trucking between two locations."""
    row = await db.execute(
        text("""
            SELECT route_name, distance_km, rate_per_ton_mmk, seasonal_variation
            FROM trucking_corridors
            WHERE route_name ILIKE :origin AND route_name ILIKE :dest
        """),
        {"origin": f"%{origin}%", "dest": f"%{destination}%"}
    )
    result = row.first()
    if not result:
        return None

    tons = weight_kg / 1000
    cost = result.rate_per_ton_mmk * tons

    return {
        "route": result.route_name,
        "distance_km": float(result.distance_km),
        "cost_mmk": round(cost, 2),
        "seasonal_variation": result.seasonal_variation,
        "estimated_hours": round(result.distance_km / 50, 1)
    }

async def get_border_status(db: AsyncSession, station_name: str) -> Optional[Dict[str, Any]]:
    """Get border station status for customs compliance."""
    row = await db.execute(
        text("""
            SELECT station_name, country, status, notes
            FROM border_trade_stations
            WHERE station_name ILIKE :name
        """),
        {"name": f"%{station_name}%"}
    )
    result = row.first()
    if not result:
        return None
    return {
        "station": result.station_name,
        "country": result.country,
        "status": result.status,
        "notes": result.notes
    }
