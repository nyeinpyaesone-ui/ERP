  value,
  onChange,
  placeholder = 'Search for a township...',
  className = '',
  disabled = false,
}) => {
  const [townships, setTownships] = useState<Township[]>([]);
  const [filtered, setFiltered] = useState<Township[]>([]);
  const [query, setQuery] = useState('');
  const [loading, setLoading] = useState(false);
  const [selected, setSelected] = useState<Township | null>(null);

  useEffect(() => {
    const loadTownships = async () => {
      setLoading(true);
      try {
        const res = await myanmarApi.getTownships();
        setTownships(res.data);
        setFiltered(res.data);
        if (value) {
          const match = res.data.find(t => t.name_en === value || t.name_mm === value);
          if (match) {
            setSelected(match);
            onChange(match);
          }
        }
      } catch (error) {
        console.error('Failed to load townships:', error);
