import React, { useState, useCallback } from 'react';
import { ShieldCheckIcon, ExclamationTriangleIcon, CheckCircleIcon } from '@heroicons/react/24/outline';
import { myanmarApi, TerminologyScan } from '../../services/api/myanmarApi';

interface TerminologyCheckProps {
  text: string;
  onCheck?: (result: TerminologyScan | null) => void;
  className?: string;
  autoCheck?: boolean;
}

export const TerminologyCheck: React.FC<TerminologyCheckProps> = ({
  text,
  onCheck,
  className = '',
  autoCheck = true,
}) => {
  const [result, setResult] = useState<TerminologyScan | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const checkTerminology = useCallback(async () => {
    if (!text.trim()) {
      setResult(null);
      onCheck?.(null);
      return;
    }

    setLoading(true);
    setError(null);
    try {
      const res = await myanmarApi.scanTerminology(text);
      setResult(res.data);
      onCheck?.(res.data);
    } catch (err) {
      setError('Failed to check terminology. Please try again.');
      setResult(null);
      onCheck?.(null);
    } finally {
      setLoading(false);
    }
  }, [text, onCheck]);

  useEffect(() => {
    if (autoCheck) {
      const debounce = setTimeout(checkTerminology, 600);
      return () => clearTimeout(debounce);
    }
  }, [text, autoCheck, checkTerminology]);

  if (loading) {
    return <div className={`animate-pulse ${className}`}><div className="h-12 rounded-lg bg-gray-200 dark:bg-gray-700" /></div>;
  }

  if (error) {
    return (
      <div className={`rounded-lg bg-red-50 dark:bg-red-900/20 p-3 ${className}`}>
        <div className="flex items-center gap-2 text-sm text-red-700 dark:text-red-400">
          <ExclamationTriangleIcon className="h-4 w-4" />
          <span>{error}</span>
        </div>
      </div>
    );
  }

  if (!result) return null;

  if (result.is_clean) {
    return (
      <div className={`rounded-lg bg-green-50 dark:bg-green-900/20 p-3 ${className}`}>
        <div className="flex items-center gap-2 text-sm text-green-700 dark:text-green-400">
          <CheckCircleIcon className="h-4 w-4" />
          <span>All terminology is correct.</span>
        </div>
      </div>
    );
  }

  return (
    <div className={`space-y-3 ${className}`}>
      <div className="rounded-lg bg-amber-50 dark:bg-amber-900/20 p-3">
        <div className="flex items-center gap-2 text-sm text-amber-700 dark:text-amber-400">
          <ShieldCheckIcon className="h-4 w-4" />
          <span className="font-medium">Terminology corrections needed</span>
        </div>
      </div>

      <div className="rounded-lg border border-amber-200 dark:border-amber-800 bg-white dark:bg-gray-800 p-4">
        {result.violations.map((violation, index) => (
          <div key={index} className="flex items-start gap-3 rounded-lg bg-gray-50 dark:bg-gray-700/50 p-3 mb-2">
            <div className="flex-1">
              <p className="text-sm">
                <span className="font-mono text-red-600 dark:text-red-400 line-through">{violation.forbidden}</span>
                <span className="mx-2 text-gray-400">→</span>
                <span className="font-mono text-green-600 dark:text-green-400">{violation.corrected}</span>
              </p>
              <p className="mt-1 text-xs text-gray-500 dark:text-gray-400">Domain: {violation.domain}</p>
            </div>
          </div>
        ))}

        <div className="mt-2 rounded-lg bg-gray-100 dark:bg-gray-700 p-3">
          <p className="text-sm text-gray-600 dark:text-gray-300"><span className="font-medium">Corrected text:</span></p>
          <p className="mt-1 text-sm text-gray-900 dark:text-white">{result.corrected}</p>
        </div>
      </div>
    </div>
  );
};
