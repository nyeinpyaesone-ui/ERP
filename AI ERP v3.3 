"""
Foundation Guard – Enforces correct Myanmar terminology.
Zero token cost – pure SQL validation.
"""

from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import text
from typing import List, Dict, Any

class TerminologyViolation(Exception):
    """Raised when forbidden terminology is detected."""

async def scan_terminology(db: AsyncSession, text_content: str) -> Dict[str, Any]:
    """Scan text for forbidden Myanmar terms and return corrections."""
    if not text_content:
        return {"original": "", "corrected": "", "violations": [], "is_clean": True}

    rows = await db.execute(
        text("SELECT forbidden_version, term_mm, domain FROM business_terms")
    )
    terms = rows.fetchall()

    corrected = text_content
    violations = []

    for term in terms:
        if term.forbidden_version and term.forbidden_version in corrected:
            corrected = corrected.replace(term.forbidden_version, term.term_mm)
            violations.append({
                "forbidden": term.forbidden_version,
                "corrected": term.term_mm,
                "domain": term.domain
            })

    return {
        "original": text_content,
        "corrected": corrected,
        "violations": violations,
        "is_clean": len(violations) == 0
    }

async def validate_terminology(db: AsyncSession, text_content: str) -> bool:
    """Validate that text contains no forbidden terms. Raises if violations found."""
    result = await scan_terminology(db, text_content)
    if not result["is_clean"]:
        violations_msg = ", ".join([v["forbidden"] for v in result["violations"]])
        raise TerminologyViolation(
            f"Forbidden Myanmar terms detected: {violations_msg}. "
            f"Use corrected versions: {result['corrected']}"
        )
    return True
