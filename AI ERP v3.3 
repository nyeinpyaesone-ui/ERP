import React, { useState } from 'react';
import { CalculatorIcon } from '@heroicons/react/24/outline';
import { myanmarApi, TaxCalculation } from '../../services/api/myanmarApi';

interface TaxCalculatorProps {
  amount: number;
  taxTypes?: string[];
  onCalculate?: (result: TaxCalculation | null) => void;
  className?: string;
}

const DEFAULT_TAX_TYPES = ['CT'];

export const TaxCalculator: React.FC<TaxCalculatorProps> = ({
  amount,
  taxTypes = DEFAULT_TAX_TYPES,
  onCalculate,
  className = '',
}) => {
  const [result, setResult] = useState<TaxCalculation | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const handleCalculate = async () => {
    if (amount <= 0) {
      setError('Please enter a valid amount');
      return;
    }

    setLoading(true);
    setError(null);
    try {
      const res = await myanmarApi.calculateTax(amount, taxTypes);
      setResult(res.data);
      onCalculate?.(res.data);
    } catch (err) {
      setError('Failed to calculate tax. Please try again.');
      setResult(null);
      onCalculate?.(null);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className={`space-y-4 ${className}`}>
      <button
        onClick={handleCalculate}
        disabled={loading || amount <= 0}
        className="flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 disabled:opacity-50"
      >
        <CalculatorIcon className="h-4 w-4" />
        {loading ? 'Calculating...' : 'Calculate Tax'}
      </button>

      {error && (
        <div className="rounded-lg bg-red-50 dark:bg-red-900/20 p-3 text-sm text-red-700 dark:text-red-400">
          {error}
        </div>
      )}

      {result && (
        <div className="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4">
          <h4 className="mb-3 text-sm font-medium text-gray-900 dark:text-white">Tax Breakdown</h4>
          <div className="space-y-2">
            {result.breakdown.map((item) => (
              <div key={item.tax_type} className="flex items-center justify-between rounded-lg bg-gray-50 dark:bg-gray-700/50 px-3 py-2">
                <div>
                  <p className="text-sm font-medium text-gray-900 dark:text-white">
                    {item.name_en}
                    <span className="ml-2 text-xs text-gray-500 dark:text-gray-400">({item.name_mm})</span>
                  </p>
                  <p className="text-xs text-gray-500 dark:text-gray-400">Rate: {(item.rate * 100).toFixed(1)}%</p>
                </div>
                <div className="text-right">
                  <p className="text-sm font-medium text-gray-900 dark:text-white">{item.amount.toLocaleString()} MMK</p>
                  <p className="text-xs text-gray-500 dark:text-gray-400">Total: {item.total_with_tax.toLocaleString()} MMK</p>
                </div>
              </div>
            ))}
          </div>

          <div className="mt-3 border-t border-gray-200 dark:border-gray-700 pt-3">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm font-medium text-gray-900 dark:text-white">Total Tax</p>
                <p className="text-xs text-gray-500 dark:text-gray-400">On {amount.toLocaleString()} MMK</p>
              </div>
              <div className="text-right">
                <p className="text-lg font-bold text-indigo-600 dark:text-indigo-400">{result.total_tax.toLocaleString()} MMK</p>
                <p className="text-sm text-gray-600 dark:text-gray-300">{result.total_with_tax.toLocaleString()} MMK including tax</p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};
