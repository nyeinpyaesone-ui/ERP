version: '3.8'

services:
  postgres:
    image: pgvector/pgvector:pg15
    container_name: ai-erp-postgres
    environment:
      POSTGRES_USER: erp_user
      POSTGRES_PASSWORD: erp_password
      POSTGRES_DB: erp_db
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U erp_user -d erp_db"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - ai-erp-net

  redis:
    image: redis:7-alpine
    container_name: ai-erp-redis
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - ai-erp-net

  qdrant:
    image: qdrant/qdrant:latest
    container_name: ai-erp-qdrant
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - qdrant_data:/qdrant/storage
    networks:
      - ai-erp-net

  ollama:
    image: ollama/ollama:latest
    container_name: ai-erp-ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    networks:
      - ai-erp-net

  n8n:
    image: n8nio/n8n:latest
    container_name: ai-erp-n8n
    ports:
      - "5678:5678"
    volumes:
      - n8n_data:/home/node/.n8n
    networks:
      - ai-erp-net

  backend:
    build: ./backend
    container_name: ai-erp-backend
    ports:
      - "8000:8000"
    environment:
      - DATABASE_URL=postgresql://erp_user:erp_password@postgres:5432/erp_db
      - REDIS_URL=redis://redis:6379/0
      - OLLAMA_BASE_URL=http://ollama:11434
      - QDRANT_HOST=qdrant
      - QDRANT_PORT=6333
      - APP_ENV=development
      - SECRET_KEY=dev_secret_key_do_not_use_in_production
      - ALGORITHM=HS256
      - ACCESS_TOKEN_EXPIRE_MINUTES=1440
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      qdrant:
        condition: service_started
      ollama:
        condition: service_started
    volumes:
      - ./backend:/app
      - uploads:/app/uploads
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
    networks:
      - ai-erp-net

  seed:
    build: ./backend
    container_name: ai-erp-seed
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      - DATABASE_URL=postgresql://erp_user:erp_password@postgres:5432/erp_db
      - APP_ENV=development
    volumes:
      - ./backend:/app
    command: >
      sh -c "alembic upgrade head &&
             python scripts/seed_domain_data.py &&
             python scripts/generate_embeddings.py"
    networks:
      - ai-erp-net
    profiles:
      - seed

  frontend:
    build: ./frontend
    container_name: ai-erp-frontend
    ports:
      - "3000:3000"
    environment:
      - NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
      - NODE_ENV=development
    volumes:
      - ./frontend:/app
      - /app/node_modules
    depends_on:
      - backend
    networks:
      - ai-erp-net

  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: ai-erp-pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@erp-domain.com
      PGADMIN_DEFAULT_PASSWORD: admin
    ports:
      - "5050:80"
    depends_on:
      - postgres
    networks:
      - ai-erp-net
    profiles:
      - tools

volumes:
  postgres_data:
  redis_data:
  qdrant_data:
  ollama_data:
  n8n_data:
  uploads:

networks:
  ai-erp-net:
    driver: bridge
