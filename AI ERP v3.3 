### setup.sh

```bash
#!/bin/bash
# AI-ERP v3.3 Complete Setup

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${BLUE}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║         🚀 AI-ERP v3.3 + AI Agent Setup                 ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════════════╝${NC}"

# Check dependencies
echo -e "${YELLOW}📋 Checking dependencies...${NC}"
for cmd in docker docker-compose python3 curl jq; do
    if ! command -v $cmd &> /dev/null; then
        echo -e "${RED}❌ $cmd not found${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ All dependencies found${NC}"

# Start services
echo -e "${BLUE}📦 Starting services...${NC}"
docker-compose up -d
sleep 15

# Pull models
echo -e "${BLUE}📦 Pulling LLM models...${NC}"
ollama pull llama3.1:8b
ollama pull codellama:7b
ollama pull qwen2.5-coder:7b

# Run migrations
echo -e "${BLUE}🗄️ Running migrations...${NC}"
docker-compose exec -T backend alembic upgrade head

# Seed domain data
echo -e "${BLUE}🌱 Seeding domain data...${NC}"
docker-compose run --rm seed

# Generate embeddings
echo -e "${BLUE}🧠 Generating embeddings...${NC}"
docker-compose exec -T backend python scripts/generate_embeddings.py

# Build knowledge base
echo -e "${BLUE}📚 Building knowledge base...${NC}"
docker-compose exec -T backend python scripts/build_erp_knowledge_base.py

# Health check
echo -e "${BLUE}🏥 Running health checks...${NC}"
curl -s http://localhost:8000/health | jq

echo -e "${GREEN}✅ Setup complete!${NC}"
echo ""
echo -e "${BLUE}Access:${NC}"
echo "  API: http://localhost:8000/docs"
echo "  Dashboard: http://localhost:3000"
echo "  Qdrant: http://localhost:6333/dashboard"
echo "  n8n: http://localhost:5678"
```

