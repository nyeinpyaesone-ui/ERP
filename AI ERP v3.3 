#!/usr/bin/env python3
"""Generate vector embeddings for all townships."""

import asyncio
import os
from sqlalchemy.ext.asyncio import create_async_engine, AsyncSession
from sqlalchemy.orm import sessionmaker
from sqlalchemy import text
from sentence_transformers import SentenceTransformer

MODEL_NAME = "all-MiniLM-L6-v2"
BATCH_SIZE = 32

async def main():
    DATABASE_URL = os.getenv("DATABASE_URL", "postgresql://erp_user:erp_password@localhost:5432/erp_db")
    engine = create_async_engine(DATABASE_URL)
    async_session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    print(f"🧠 Loading model: {MODEL_NAME}")
    model = SentenceTransformer(MODEL_NAME)

    async with async_session() as session:
        rows = await session.execute(
            text("SELECT id, name_en, name_mm, region_state FROM townships WHERE embedding IS NULL")
        )
        townships = rows.fetchall()

        if not townships:
            print("✅ All townships already have embeddings.")
            return

        print(f"Generating embeddings for {len(townships)} townships...")

        for i in range(0, len(townships), BATCH_SIZE):
            batch = townships[i:i+BATCH_SIZE]
            texts = [f"{t.name_en} {t.name_mm} {t.region_state}" for t in batch]
            embeddings = model.encode(texts).tolist()

            for township, emb in zip(batch, embeddings):
                await session.execute(
                    text("UPDATE townships SET embedding = :emb WHERE id = :id"),
                    {"emb": emb, "id": township.id}
                )

            print(f"Processed {min(i+BATCH_SIZE, len(townships))}/{len(townships)}")

        await session.commit()
        print("✅ Embeddings generated successfully!")

if __name__ == "__main__":
    asyncio.run(main())
