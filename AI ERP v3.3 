"""
Finance Agent Skills – Deterministic tax calculation.
Zero token cost – pure SQL queries on tax_rates table.
"""

from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import text
from typing import List, Dict, Any

async def get_tax_rate(db: AsyncSession, tax_type: str) -> Optional[float]:
    """Get the current active tax rate for a given type."""
    row = await db.execute(
        text("""
            SELECT rate FROM current_tax_rates
            WHERE tax_type = :tax_type
        """),
        {"tax_type": tax_type}
    )
    result = row.first()
    return float(result.rate) if result else None

async def calculate_tax(
    db: AsyncSession,
    amount: float,
    tax_types: List[str]
) -> Dict[str, Any]:
    """Calculate tax breakdown for a given amount and tax types."""
    rows = await db.execute(
        text("""
            SELECT tax_type, tax_name_en, tax_name_mm, rate
            FROM current_tax_rates
            WHERE tax_type = ANY(:types)
            ORDER BY tax_type
        """),
        {"types": tax_types}
    )
    results = rows.fetchall()

    breakdown = []
    total_tax = 0.0
    for row in results:
        tax_amount = amount * row.rate
        total_tax += tax_amount
        breakdown.append({
            "tax_type": row.tax_type,
            "name_en": row.tax_name_en,
            "name_mm": row.tax_name_mm,
            "rate": float(row.rate),
            "amount": round(tax_amount, 2),
            "total_with_tax": round(amount + tax_amount, 2)
        })

    return {
        "breakdown": breakdown,
        "total_tax": round(total_tax, 2),
        "total_with_tax": round(amount + total_tax, 2)
    }

async def calculate_ct(db: AsyncSession, amount: float) -> Dict[str, Any]:
    """Convenience: calculate Commercial Tax (CT) only."""
    return await calculate_tax(db, amount, ["CT"])

async def calculate_cit(db: AsyncSession, profit: float) -> float:
    """Convenience: calculate Corporate Income Tax (CIT)."""
    rate = await get_tax_rate(db, "CIT")
    if rate is None:
        return 0.0
    return round(profit * rate, 2)
