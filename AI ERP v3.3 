  - port: http
    path: /metrics
    interval: 30s
    scrapeTimeout: 10s
---
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: ai-erp-alerts
  namespace: ai-erp-monitoring
  labels:
    app.kubernetes.io/name: ai-erp-alerts
    app.kubernetes.io/part-of: ai-erp
    release: prometheus
spec:
  groups:
  - name: ai-erp
    rules:
    - alert: AIERPApiHighErrorRate
      expr: |
        (sum(rate(http_requests_total{job=~"ai-erp-api",status=~"5.."}[5m])) / sum(rate(http_requests_total{job=~"ai-erp-api"}[5m]))) > 0.05
      for: 5m
      labels:
        severity: critical
      annotations:
        summary: "AI-ERP API High Error Rate"
        description: "Error rate is above 5% for {{ $labels.namespace }}/{{ $labels.pod }}"

    - alert: AIERPApiHighLatency
      expr: |
        histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~"ai-erp-api"}[5m])) by (le, namespace, pod)) > 2
      for: 5m
      labels:
        severity: warning
      annotations:
        summary: "AI-ERP API High Latency"
        description: "P95 latency is above 2s for {{ $labels.namespace }}/{{ $labels.pod }}"

    - alert: AIERP_TownshipQuerySlow
      expr: |
        histogram_quantile(0.95, sum(rate(township_query_duration_seconds_bucket[5m])) by (le)) > 0.01
      for: 5m
      labels:
        severity: warning
      annotations:
        summary: "Township query P95 > 10ms"
        description: "Delivery fee lookups are slow, check pgvector index."

    - alert: AIERP_FoundationGuardViolation
      expr: |
        increase(foundation_guard_violations_total[1h]) > 0
      for: 1m
      labels:
        severity: critical
      annotations:
        summary: "Forbidden terminology detected in AI output"
        description: "Check AI logs and business_terms table."
